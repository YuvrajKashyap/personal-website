NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase placeholders for future data/admin steps.
# Do not commit real values. Put real local values in .env.local only.
# The public app keeps local fallback behavior until Supabase is configured.
# SITE_DATA_SOURCE supports local, auto, or supabase. The default is local.
SITE_DATA_SOURCE=local

# NEXT_PUBLIC values are browser-visible.
# Prefer the publishable key for public client operations when available.
# The anon key remains as a legacy fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose these to browser/client code.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Project ref is not a secret, but keep it placeholder-only until the project is selected.
SUPABASE_PROJECT_REF=
