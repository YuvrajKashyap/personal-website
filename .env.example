NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase placeholders for future data/admin steps.
# Do not commit real values. Put real local values in .env.local only.
# NEXT_PUBLIC values are browser-visible and should only be used after the data layer step connects Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref is not a secret, but keep it placeholder-only until the project is selected.
SUPABASE_PROJECT_REF=
